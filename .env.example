# ═══════════════════════════════════════════════════════════
# OPTCG Market Terminal — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database (PostgreSQL) ──────────────────────────────────
# Supabase connection string (get from Supabase Dashboard > Settings > Database)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ─── JWT Authentication ──────────────────────────────────────
# IMPORTANT: Generate a strong random secret in production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_EXPIRE_DAYS=30

# ─── One Piece Card Game API (RapidAPI) ──────────────────────
# Sign up at: https://rapidapi.com/api-sports/api/one-piece-card-game1
# Plan: Ultra ($24.90/mo) = 15,000 req/day, 300 req/min
# Source: EU prices (Cardmarket EUR) — used for EU price data only
RAPIDAPI_KEY=your-rapidapi-key-here
RAPIDAPI_HOST=one-piece-tcg-prices.p.rapidapi.com

# ─── TCG Price Lookup (EN Prices — TCGPlayer + eBay) ─────────
# Sign up at: https://tcgpricelookup.com
# Provides: EN TCGPlayer market/low (USD) + eBay avg 7d (USD)
# Free tier: 200 req/day (sufficient for development)
# Trader plan: required for eBay prices
TCG_PRICE_LOOKUP_KEY=your-tcg-price-lookup-key-here

# ─── Stripe ──────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs — create in Stripe Dashboard > Products
# Pro tier: CHF 19/month (Early Bird)
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# Elite tier: CHF 69/month
STRIPE_ELITE_PRICE_ID=price_your-elite-price-id

# ─── App URL ─────────────────────────────────────────────────
# Used for Stripe redirect URLs — no trailing slash
APP_URL=http://localhost:8000

# In production:
# APP_URL=https://yourdomain.com

# ─── Arbitrage Cost Configuration ────────────────────────────
# These defaults match EU↔US trade costs but can be tuned

# FX spread cost (EUR↔USD conversion overhead, default 3%)
ARB_FX_SPREAD=0.03

# Shipping costs in EUR
ARB_SHIPPING_EU_US=17.0    # EU to US per shipment
ARB_SHIPPING_US_EU=22.0    # US to EU per shipment

# Marketplace fees (as decimals)
ARB_CM_FEE=0.05            # Cardmarket seller fee (5%)
ARB_TCG_FEE=0.13           # TCGPlayer seller fee (13%)

# Minimum profit threshold to show signal (default 5%)
ARB_PROFIT_THRESHOLD=0.05

# Watch zone threshold (default 2%)
ARB_WATCH_THRESHOLD=0.02

# ─── Server ──────────────────────────────────────────────────
PORT=8000
